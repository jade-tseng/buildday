# Base URL of the FastAPI backend the frontend calls.
# Local dev defaults to http://localhost:8000 (see src/util/api.ts), so this is
# only needed for the deployed build.
#
# Production: point at the Cloud Run service URL, e.g.
# VITE_API_URL=https://rewilding-api-xxxxxxxx-uc.a.run.app
VITE_API_URL=
